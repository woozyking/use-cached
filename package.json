{
  "name": "use-cached",
  "version": "3.0.0",
  "author": "woozyking <runzhou.li@gmail.com>",
  "license": "MIT",
  "description": "React hook for caching states in localStorage with TTL/expiration support",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/woozyking/use-cached.git"
  },
  "type": "module",
  "private": false,
  "main": "./dist/use-cached.umd.cjs",
  "module": "./dist/use-cached.js",
  "source": "src/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/use-cached.js",
      "require": "./dist/use-cached.umd.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "prop-types": "^15.8.1",
    "react": "^19",
    "react-dom": "^19",
    "storybook": "^10.3.6",
    "vite": "^8.0.12"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "bugs": {
    "url": "https://github.com/woozyking/use-cached/issues"
  },
  "homepage": "https://github.com/woozyking/use-cached#readme",
  "keywords": [
    "react",
    "hook",
    "cache",
    "localstorage"
  ]
